<!-- ===================================================================== -->
<!-- Universal Crafter Configurable Properties -->
<!-- ===================================================================== -->

<!-- CraftingSpeed
     OPTIONAL
     Multiplier applied to crafting speed.
     Read dynamically each tick via block properties.

     NOTES:
     - If missing or invalid, defaults to 1.0
-->
<!-- Example:
     <property name="CraftingSpeed" value="1.5" />
-->

<!-- DevLogs
     OPTIONAL
     Enables verbose logging for this block and its TileEntity.
     Affects:
       - Craft lifecycle
       - Container resolution
       - Ingredient checks
       - Save / load
-->
<!-- Example:
     <property name="DevLogs" value="true" />
-->

<!-- ===================================================================== -->
<!-- HOW IT WORKS BACKEND -->
<!-- ===================================================================== -->
<!--
 - The crafter scans ALL recipes when opened.
 - Only recipes unlocked by the CURRENT PLAYER are shown.
 - Selected recipe name is persisted.
 - Craft timing is based on:
     BaseRecipeDuration (seconds) / CraftingSpeed
 - Internally:
     worldTime ticks are converted to seconds (ticks / 20f).
 - Ingredients are pulled ONLY from the selected input container.
 - Output is deposited ONLY into the selected output container.
 - If ingredients or containers are missing, crafting pauses safely.
-->

<!-- ===================================================================== -->
<!-- Universal Extractor Configurable Properties              -->
<!-- ===================================================================== -->

<!-- ResourceGenerated
     REQUIRED
     Comma-separated list of item names to produce.
-->
<!-- Example:
     <property name="ResourceGenerated" value="resourceScrapIron,resourceLead" />
-->

<!-- OutputCount
     OPTIONAL
     Output amount per production cycle.
     Supports:
       - Fixed: "5"
       - Range: "1-7"
     One entry per ResourceGenerated item.
-->
<!-- Example:
     <property name="OutputCount" value="1-3,2-5" />
-->

<!-- ExtractionSpeed
     OPTIONAL
     Production interval in TICKS.
     (20 ticks = 1 second)

     NOTES:
     - This value is used directly as a tick counter
     - Default is 300 ticks if not provided
-->
<!-- Example:
     <property name="ExtractionSpeed" value="300,600" />
-->

<!-- DevLogs
     OPTIONAL
     Enables verbose logging for this block and its TileEntity.
     Includes:
       - Timer ticks
       - Storage checks
       - Production output
       - Save / load
-->
<!-- Example:
     <property name="DevLogs" value="true" />
-->


<!-- ===================================================================== -->
<!-- HOW IT WORKS (Extractor Actual)                                     -->
<!-- ===================================================================== -->
<!--
 - On first update, the extractor reads its XML properties and builds timers.
 - Each timer increments once per UpdateTick.
 - When Counter >= ExtractionSpeed:
     - Counter resets
     - Output is queued
 - OutputCount may be randomized per cycle.
 - Items are deposited into ANY nearby valid storage.
 - If no storage exists, the extractor shuts off automatically.
-->


<!-- ===================================================================== -->
<!-- PIPES                                                                   -->
<!-- ===================================================================== -->
<!-- PipeThroughput
     OPTIONAL
     Max items moved per transport job.
     Integer >= 1. Higher = more items per job.
-->
<!-- PipeSpeed
     OPTIONAL
     Travel-speed multiplier used for A->B travel time.
     Integer >= 1. Higher = faster travel (fewer ticks per segment).
-->
<!-- PipeLatency
     OPTIONAL
     Dispatch-rate multiplier used for time between job attempts.
     Integer >= 1. Higher = shorter delay between attempts.
-->
<!-- Route behavior:
     - Throughput/Speed/Latency all use bottleneck logic across the route.
     - Lowest pipe value on the route wins.
     - Missing/invalid values fall back to 1 in code.
-->
<!-- Example:
     <property name="PipeThroughput" value="5" />
     <property name="PipeSpeed" value="2" />
     <property name="PipeLatency" value="3" />
-->
