<configs>
	<append xpath="/recipes">
		<!-- MACHINE RECIPES -->

		<!-- FLUID DECANTER -->

		<machineRecipe name="water_from_boiled_jar" machine="fluiddecanter">
			<input item="drinkJarBoiledWater" count="1" />
			<output item="drinkJarEmpty" count="1" />
			<fluid_output type="water" gallons="0.5" />
		</machineRecipe>

		<machineRecipe name="gas_from_gas_can" machine="fluiddecanter">
			<input item="ammoGasCan" count="1" />
			<output item="resourceScrapPolymers" count="10" />
			<fluid_output type="gas" gallons="2" />
		</machineRecipe>

		<!-- FLUID INFUSER -->

		<machineRecipe name="water_jar" machine="fluidinfuser">
			<input item="drinkJarEmpty" count="1" />
			<fluid_input type="water" gallons="0.5" />
			<output item="drinkJarBoiledWater" count="1" />
		</machineRecipe>

		<machineRecipe name="murky_water_jar" machine="fluidinfuser">
			<input item="drinkJarEmpty" count="1" />
			<fluid_input type="murky_water" gallons="0.5" />
			<output item="drinkJarRiverWater" count="1" />
		</machineRecipe>

		<machineRecipe name="ammogascan" machine="fluidinfuser">
			<input item="resourceScrapPolymers" count="10" />
			<fluid_input type="gas" gallons="2" />
			<output item="ammoGasCan" count="1" />
