			<output item="resourceOil" count="1" />
		</machineRecipe>

		<!-- MELTER -->

		<machineRecipe name="melt_oil_shale" machine="melter">
			<heat value="30" />
			<input item="resourceOilShale" count="5" />
			<fluid_output type="molten_oil" gallons="0.25" />
		</machineRecipe>

		<machineRecipe name="melt_scrap_iron" machine="melter">
			<heat value="20" />
			<input item="resourceScrapIron" count="10" />
			<fluid_output type="molten_iron" gallons="0.1" />
		</machineRecipe>

		<machineRecipe name="melt_steel" machine="melter">
			<heat value="50" />
			<input item="resourceScrapIron" count="20" />
			<fluid_output type="molten_steel" gallons="0.1" />
		</machineRecipe>

		<machineRecipe name="melt_stone" machine="melter">
			<heat value="20" />
			<input item="resourceRockSmall" count="2" />
			<fluid_output type="molten_stone" gallons="0.2" />
