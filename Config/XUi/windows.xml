<configs>

    <append xpath="/windows">

        <window name="windowIronExtractorInfo" controller="IronExtractorInfo, 7DaysToAutomate" width="760" height="380" panel="Center">
            <rect pos="0,-100">

                <!-- LEFT: EXTRACTOR WINDOW -->
                <rect pos="0,0">

                    <panel name="header" width="450" height="50" depth="1">
                        <sprite depth="2" name="backgroundMain" sprite="ui_game_panel_header" color="[darkestGrey]"/>
                        <label depth="6" pos="0,-6" width="450" height="40" text="{extractorname}" font_size="36" justify="center" color="[limeGreen]" effect="outline"/>
                    </panel>

                    <rect name="content" pos="0,-50" height="330">
                        <sprite depth="1" name="bg" width="450" height="500" type="sliced" color="[black]" alpha="0.8"/>

                        <label depth="5" pos="0,-30" width="450" height="50" text="PRODUCTION" justify="center" font_size="40" upper_case="true" color="[limeGreen]" effect="outline" effect_distance="2,2" effect_color="[black]"/>

                        <label depth="6" pos="30,-90" width="390" text="{production}" multiline="true" font_size="30" color="[white]" line_spacing="42"/>
                        <rect pos="355,-110" visible="{fluidfuelvisible}">
                            <label depth="6" pos="-10,-20" width="70" height="24" text="Fuel" justify="center" font_size="20" color="[limeGreen]" effect="outline"/>
                            <sprite depth="5" pos="0,0" width="36" height="130" sprite="menu_empty3px" type="sliced" color="[black]" fillcenter="false"/>
                            <sprite depth="5" pos="2,-2" width="32" height="126" type="sliced" color="[darkGrey]" visible="{fluidfueldisabled}"/>
                            <filledsprite depth="6" pos="2,-2" width="32" height="126" type="filled" fill="{fluidfuelfill}" color="0,180,90,200" visible="{fluidfuelenabled}" filldirection="vertical"/>
                            <!-- <label depth="7" pos="-24,-56" width="84" height="28" text="{fluidfueltext}" justify="center" font_size="18" color="[white]" effect="outline"/> -->
                            <label depth="6" pos="-45,-142" width="130" height="24" text="{fluidfuelstatus}" justify="center" font_size="16" color="[white]"/>
                        </rect>
                    </rect>

                    <!-- REQUIREMENTS -->
                    <rect pos="0,-285">
                        <label depth="5" pos="0,0" width="450" height="50" text="REQUIREMENTS" justify="center" font_size="40" upper_case="true" color="[limeGreen]" effect="outline" effect_distance="2,2" effect_color="[black]"/>

                        <label depth="6" pos="30,-70" width="400" height="30" text="Valid Output Target" color="[green]" visible="{hasstorage}"/>
                        <label depth="6" pos="30,-70" width="400" height="30" text="Valid Output Target" color="[red]" visible="{nothasstorage}"/>
                    </rect>

                    <!-- POWER BUTTON -->
                    <rect pos="225,-500">
                        <label depth="4" pos="5,0" pivot="center" width="100" height="30" text="{powerbutton}" font_size="32" color="[limeGreen]" effect="outline"/>
                        <button depth="3" name="powerbutton" sprite="menu_empty" defaultcolor="[mediumGrey]" hoversprite="ui_game_select_row" hovercolor="[white]" pivot="center" type="sliced" hoverscale="1" sound="[paging_click]" width="130" height="30"/>
                    </rect>

                    <!-- PIPE PRIORITY -->
                    <rect pos="225,-425">
                        <label depth="4" pos="-45,0" width="90" height="30" text="Priority" font_size="26" justify="center" color="[limeGreen]" effect="outline"/>
                        <button depth="4" name="prioritydownbutton" pos="-56,-24" width="20" height="30" sprite="ui_game_symbol_arrow_left" defaultcolor="[white]" hovercolor="[limeGreen]" hoverscale="1" sound="[paging_click]" tooltip="Decrease pipe priority (0-9). Higher number = higher priority."/>
                        <textfield name="extractorPriorityInput" pos="-30,-25" width="60" height="28" text="{pipepriority}" tooltip="Set pipe priority from 0 to 9. Higher number = higher priority." />
                        <button depth="4" name="priorityupbutton" pos="36,-24" width="20" height="30" sprite="ui_game_symbol_arrow_right" defaultcolor="[white]" hovercolor="[limeGreen]" hoverscale="1" sound="[paging_click]" tooltip="Increase pipe priority (0-9). Higher number = higher priority."/>
                    </rect>

                    <!-- CLOSE BUTTON -->
                    <button depth="10" name="closeButton" pos="415,-25" width="35" height="35" pivot="center" sprite="ui_game_symbol_x" defaultcolor="[white]" hovercolor="[red]" type="sliced" sound="[paging_click]" on_press="true"/>

                </rect>

                <!-- RIGHT: OUTPUT CONTAINERS -->
                <rect pos="460,0">
                    <panel name="containerPanel" pos="-2,0" width="300" height="40" depth="1">
                        <sprite depth="2" name="backgroundMain" sprite="ui_game_panel_header" color="[darkestGrey]"/>
                        <label depth="6" pos="-75,-4" width="450" height="40" text="Output Container" font_size="32" justify="center" color="[limeGreen]" effect="outline"/>
                    </panel>

                    <grid name="outputContainers" rows="2" cols="5" pos="0,-50" cell_width="60" cell_height="60" width="280" height="150" repeat_content="true" arrangement="horizontal" controller="ExtractorOutputContainerList, 7DaysToAutomate">
                        <extractor_output_container_entry name="0"/>
                    </grid>
                </rect>

            </rect>
        </window>

